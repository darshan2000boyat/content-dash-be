{
  "kind": "collectionType",
  "collectionName": "sitemaps",
  "info": {
    "singularName": "sitemap",
    "pluralName": "sitemaps",
    "displayName": "1.0.0 - Sitemap",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "PageTitle": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "string"
    },
    "PageURL": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "uid",
      "targetField": "PageTitle"
    },
    "ExcludeFromSitemap": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "boolean",
      "default": false,
      "private": true
    },
    "SEO": {
      "displayName": "SEO",
      "type": "component",
      "repeatable": false,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "global.seo"
    },
    "Blocks": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "dynamiczone",
      "components": [
        "blocks.two-column-content-block",
        "blocks.full-width-image"
      ]
    },
    "PageType": {
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "type": "enumeration",
      "enum": [
        "default",
        "news-listing",
        "news-detail"
      ],
      "default": "default",
      "required": true
    }
  }
}
